# Cron (Vercel): Authorization: Bearer <CRON_SECRET> or exact value
CRON_SECRET=

# Weekend cron: Google Places API (New) text search
GOOGLE_PLACES_API_KEY=

# Reddit: official API (password grant preferred; else client_credentials)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=foodtrend-la/0.1 by YOUR_REDDIT_USERNAME

# GitHub write-back for data/la-food-trends.json (Contents API; no local fs)
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_BRANCH=main
