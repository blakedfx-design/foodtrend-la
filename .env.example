# Cron (Vercel): Authorization: Bearer <CRON_SECRET> or exact value
CRON_SECRET=

# Google Places API (New) — live HTTP when set; drives discovery / geo signals
GOOGLE_PLACES_API_KEY=

# Reddit: official API (password grant preferred; else client_credentials)
# Note: trend-signal adapter may still be a stub; see README "Data sources (integrity)".
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=foodtrend-la/0.1 by YOUR_REDDIT_USERNAME

# External reservation platform APIs — optional; registry/diagnostic connectors only until adapters ingest
RESY_API_KEY=
OPENTABLE_API_KEY=
TOCK_API_KEY=

# GitHub write-back for data/la-food-trends.json (Contents API; no local fs)
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_BRANCH=main
